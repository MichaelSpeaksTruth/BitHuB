{
  "rewrites": [
    {
      "source": "/dev-root/(.*)",
      "destination": "https://bithub-jaipur.onrender.com/dev-root/$1"
    },
    {
      "source": "/api/(.*)",
      "destination": "https://bithub-jaipur.onrender.com/api/$1"
    },
    {
      "source": "/study-material/(.*)",
      "destination": "https://bithub-jaipur.onrender.com/study-material/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
